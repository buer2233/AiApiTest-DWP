# 后端环境变量示例（复制为 .env 后填入本地/部署值；.env 不提交）
# 所有值均为占位符，不含真实凭据

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
DJANGO_TIME_ZONE=Asia/Shanghai

# 数据库（Compose 中 DB_HOST 用 mysql 服务名）
DB_ENGINE=django.db.backends.mysql
DB_NAME=hermes_platform
DB_USER=hermes
DB_PASSWORD=change-me
DB_HOST=mysql
DB_PORT=3306

# api-test 用例根目录（容器内为挂载卷路径）
API_TEST_ROOT=/app/api-test
