// Jenkins Pipeline 入口文件。
// 该文件只负责在 Jenkins node 上拉取源码并加载可复用 Groovy Pipeline，
// 具体参数、stage 编排和 api-test 调用逻辑统一维护在 scripts/api-test-pipeline.groovy。
node {
    // 先检出仓库，确保后续 load 能读取 workspace 中的 Groovy 脚本。
    checkout scm

    // 将主体 Pipeline 放到独立脚本中，便于静态测试和后续复用。
    def pipelineScript = load 'jenkins/scripts/api-test-pipeline.groovy'
    pipelineScript.call()
}
